package com.ecommerce.app.config;

import com.ecommerce.app.entity.User;
import com.ecommerce.app.repository.UserRepository;
import org.springframework.boot.CommandLineRunner;
import org.springframework.context.annotation.Bean;
import org.springframework.context.annotation.Configuration;
import org.springframework.security.crypto.bcrypt.BCryptPasswordEncoder;

@Configuration
public class AdminInitializer {

    @Bean
    CommandLineRunner initAdmin(UserRepository repo, BCryptPasswordEncoder encoder) {
        return args -> {
            if (repo.findByUsername("admin@gmail.com").isEmpty()) {

                User u = new User();
                u.setUsername("admin@gmail.com");
                u.setPassword(encoder.encode("admin123"));
                u.setRole("ADMIN"); // or ROLE_ADMIN based on earlier fix

                repo.save(u);
            }
        };
    }
}
